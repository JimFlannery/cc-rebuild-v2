# ── Solana ──────────────────────────────────────────────────────────────────
# Path to the oracle wallet keypair (JSON array of bytes).
# This wallet must be the authorized oracle signer in the Anchor program.
# Fund it with SOL (gas) and LINK (oracle gas) on devnet before running.
ORACLE_KEYPAIR_PATH=~/.config/solana/oracle-keypair.json

# "devnet", "testnet", or "mainnet-beta"
SOLANA_CLUSTER=devnet

# Deployed program ID from Anchor.toml
PROGRAM_ID=5PkPCbdZNFGYVJNjifxgZDGyeaMKmTeWPj4fxhYeeB9K

# ── MySQL ────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=condition_cover
DB_USER=oracle
DB_PASSWORD=

# ── NOAA SWPC ────────────────────────────────────────────────────────────────
# Base URL for the NOAA Space Weather Prediction Center data server.
# No API key required.
NOAA_BASE_URL=https://services.swpc.noaa.gov

# ── Notes ─────────────────────────────────────────────────────────────────────
# Dst is now served as JSON by NOAA at products/kyoto-dst.json — no separate
# Kyoto WDC URL is needed. Both Kp and Dst use NOAA_BASE_URL above.
